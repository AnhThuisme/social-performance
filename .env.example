# App
PORT=8000
UVICORN_HOST=0.0.0.0
UVICORN_RELOAD=false
ROW_SCAN_DELAY_SECONDS=0.12
START_ROW=2
APP_TIMEZONE=Asia/Bangkok
SHEET_CACHE_TTL_SECONDS=45

# Default sheet
DEFAULT_SHEET_ID=
DEFAULT_SHEET_NAME=

# Auth
AUTH_BOOTSTRAP_ADMIN_EMAIL=
AUTH_SETTINGS_KV_KEY=social-monitor:auth-settings
APP_RUNTIME_STATE_KEY=social-monitor:runtime-state
AUTH_SETTINGS_REDIS_URL=
REDIS_URL=

# Persistent auth storage on Vercel/Upstash Redis: use one pair only
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google credentials: use one option only
SERVICE_ACCOUNT_FILE=credential.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Gmail SMTP defaults
GMAIL_SMTP_EMAIL=
GMAIL_SMTP_APP_PASSWORD=
GMAIL_SMTP_FROM_EMAIL=

# OTP SMTP override
AUTH_SMTP_HOST=
AUTH_SMTP_PORT=587
AUTH_SMTP_USER=
AUTH_SMTP_PASSWORD=
AUTH_SMTP_FROM_EMAIL=
AUTH_SMTP_FROM_NAME=Social Monitor
AUTH_SMTP_USE_TLS=true
AUTH_SMTP_USE_SSL=false

# APIs
YOUTUBE_API_KEY=

# Selenium
SELENIUM_REMOTE_URL=
REMOTE_WEBDRIVER_URL=
SELENIUM_REMOTE_BROWSER=chrome
CHROME_BIN=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver
EDGE_BIN=
MSEDGEDRIVER_PATH=
