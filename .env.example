# App
PORT=8000
UVICORN_HOST=0.0.0.0
UVICORN_RELOAD=false
ROW_SCAN_DELAY_SECONDS=0.0
POSTS_TAB_BUILD_STAGGER_SECONDS=0.0
POSTS_LAYOUT_SAMPLE_ROWS=24
POSTS_LAYOUT_USE_CACHE=true
START_ROW=2
APP_TIMEZONE=Asia/Bangkok
SHEET_CACHE_TTL_SECONDS=45
BATCH_SHEET_WRITES=true
RESET_STALE_SELENIUM_ON_START=false
ENABLE_SUCCESS_METRIC_ZERO_CHECK=false

# Default sheet
DEFAULT_SHEET_ID=
DEFAULT_SHEET_NAME=

# Auth
AUTH_BOOTSTRAP_ADMIN_EMAIL=
AUTH_SETTINGS_KV_KEY=social-monitor:auth-settings
APP_RUNTIME_STATE_KEY=social-monitor:runtime-state
AUTH_SETTINGS_REDIS_URL=
REDIS_URL=

# Persistent auth storage on Vercel/Upstash Redis: use one pair only
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google credentials: use one option only
SERVICE_ACCOUNT_FILE=credential.json
GOOGLE_SERVICE_ACCOUNT_JSON=

GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=


# Gmail SMTP defaults
GMAIL_SMTP_EMAIL=
GMAIL_SMTP_APP_PASSWORD=
GMAIL_SMTP_FROM_EMAIL=

# OTP SMTP override
AUTH_SMTP_HOST=
AUTH_SMTP_PORT=587
AUTH_SMTP_USER=
AUTH_SMTP_PASSWORD=
AUTH_SMTP_FROM_EMAIL=
AUTH_SMTP_FROM_NAME=Social Monitor
AUTH_SMTP_USE_TLS=true
AUTH_SMTP_USE_SSL=false

# APIs
YOUTUBE_API_KEY=

# Selenium
SELENIUM_REMOTE_URL=
SELENIUM_HUB_URL=
REMOTE_WEBDRIVER_URL=
SELENIUM_REMOTE_BROWSER=chrome
SELENIUM_PAGE_LOAD_TIMEOUT_SECONDS=14
SELENIUM_TIKTOK_PAGE_LOAD_TIMEOUT_SECONDS=12
SELENIUM_FACEBOOK_PAGE_LOAD_TIMEOUT_SECONDS=12
SELENIUM_INSTAGRAM_PAGE_LOAD_TIMEOUT_SECONDS=9
SELENIUM_TIKTOK_SOFT_RETRY_ATTEMPTS=1
SELENIUM_TIKTOK_SOFT_RETRY_DELAY_SECONDS=1.0
SELENIUM_FACEBOOK_SOFT_RETRY_ATTEMPTS=1
SELENIUM_FACEBOOK_SOFT_RETRY_DELAY_SECONDS=1.0
SELENIUM_INSTAGRAM_SOFT_RETRY_ATTEMPTS=1
SELENIUM_INSTAGRAM_SOFT_RETRY_DELAY_SECONDS=0.8
SELENIUM_TIMEOUT_RECOVERY_RETRY_ATTEMPTS=1
SELENIUM_TIMEOUT_RECOVERY_RETRY_DELAY_SECONDS=0.8
SELENIUM_TIKTOK_TIMEOUT_STREAK_THRESHOLD=2
SELENIUM_TIKTOK_TIMEOUT_COOLDOWN_SECONDS=45
SELENIUM_SETTLE_SECONDS=1.5
SELENIUM_SCROLL_SETTLE_SECONDS=0.18
SELENIUM_READY_POLL_SECONDS=0.15
SELENIUM_READY_TIMEOUT_SECONDS=10
TIKTOK_MANUAL_CHALLENGE_TIMEOUT_SECONDS=12
TIKTOK_MANUAL_CHALLENGE_POLL_SECONDS=0.8
TIKTOK_AUTO_WAIT_TIMEOUT_SECONDS=26
TIKTOK_AUTO_WAIT_POLL_SECONDS=1.0
TIKTOK_VISUAL_RETRY_WAIT_SECONDS=18
SELENIUM_REMOTE_RETRY_ATTEMPTS=3
SELENIUM_REMOTE_RETRY_DELAY_SECONDS=2
SELENIUM_REMOTE_PAGE_LOAD_TIMEOUT_SECONDS=30
SELENIUM_REMOTE_STATUS_REQUEST_TIMEOUT_SECONDS=8
SELENIUM_REMOTE_STATUS_TIMEOUT_SECONDS=75
SELENIUM_REMOTE_STATUS_POLL_SECONDS=2
SELENIUM_REMOTE_READY_CACHE_SECONDS=12
CHROME_BIN=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver
EDGE_BIN=
MSEDGEDRIVER_PATH=
# Session helpers for anti-bot-heavy platforms like TikTok
SELENIUM_ALLOW_VISIBLE_RETRY=1
SELENIUM_XVFB_AUTO_START=1
SELENIUM_XVFB_DISPLAY=:99
SELENIUM_CHROME_USER_DATA_DIR=
SELENIUM_CHROME_PROFILE_DIRECTORY=
FB_COOKIES_JSON=
TT_COOKIES_JSON=
TT_COOKIES_FILE=
IG_COOKIES_JSON=
